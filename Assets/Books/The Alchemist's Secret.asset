  m_Script: {fileID: 11500000, guid: 85339989043ca1a409c4e5230098884b, type: 3}
  m_Name: The Alchemist's Secret
  m_EditorClassIdentifier: 
  bookTitle: The Alchemist's Secret
  coverImage: {fileID: 21300000, guid: 898ff29d6e3eff741bedcd0f1bfb9e41, type: 3}
  worldIcon: {fileID: 21300000, guid: 898ff29d6e3eff741bedcd0f1bfb9e41, type: 3}
  pageContent: '"...To turn lead into pure gold, fire alone is not enough. One must
    mix the pollen of a mountain edelweiss with three drops of morning dew collected
    on the day of the spring equinox. When the solution begins to glow turquoise,
    slowly pour in crushed emerald. Remember: if the cauldron starts to shake, stop
    the process immediately. The true philosopher''s stone is born not in fire, but
    in the patience of the one who creates it..."'
