  m_Script: {fileID: 11500000, guid: 85339989043ca1a409c4e5230098884b, type: 3}
  m_Name: Sherlock Holmes
  m_EditorClassIdentifier: 
  bookTitle: Sherlock Holmes Casebook
  coverImage: {fileID: 21300000, guid: a34c82ed71e397449b56451d7535f467, type: 3}
  worldIcon: {fileID: 21300000, guid: a34c82ed71e397449b56451d7535f467, type: 3}
  pageContent: "\"\u2014 You see, but you do not observe, Watson, \u2014 Holmes said
    thoughtfully, blowing a ring of smoke. \u2014 Look at this cigarette butt by
    the fireplace. Its ash is darker than usual, indicating a rare brand of tobacco
    sold only in one shop on Regent Street. The owner of these boots left a trail
    with a slight emphasis on the left heel \u2014 he was clearly wounded while serving
    in the colonies. The criminal thought he had escaped, but he left an entire biography
    in this room...\""
